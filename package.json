{
  "name": "blog-api",
  "version": "1.0.0",
  "description": "RESTful Blog API for JAMstack project (TOP)",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "PORT=4000 NODE_ENV=production LOG_LEVEL=info node src/server.js",
    "start:worker": "NODE_ENV=production LOG_LEVEL=info node src/jobs/worker.js",

    "dev": "PORT=4001 NODE_ENV=development LOG_LEVEL=debug node --watch src/server.js",
    "dev:api": "PORT=4001 NODE_ENV=development LOG_LEVEL=debug node src/server.js",
    "dev:worker": "NODE_ENV=development LOG_LEVEL=debug node src/jobs/worker.js",
    "dev:runOnce": "NODE_ENV=development LOG_LEVEL=debug node src/jobs/runOnce.js",

    "prod:test:api": "PORT=4000 NODE_ENV=production LOG_LEVEL=info node src/server.js",
    "prod:test:worker": "NODE_ENV=production LOG_LEVEL=info node src/jobs/worker.js",
    "prod:test:runOnce": "NODE_ENV=production LOG_LEVEL=info node src/jobs/runOnce.js",

    "seed": "node src/config/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@prisma/config": "^7.1.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "express-xss-sanitizer": "^2.0.0",
    "file-type": "^21.1.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.11",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.5.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "prisma": "^6.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
