// Prisma schema (language-scoped NO/EN across content + rankings + featured + badges)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Language {
  NO
  EN
}

enum Role {
  ADMIN
  USER
}

enum FeatureType {
  DAILY_JOKE
  TOP_CREATOR_MONTH
  TRENDING_WEEK
  MOST_COMMENTED_WEEK
  FASTEST_GROWING
}

enum BadgeKey {
  ADMIN
  TOP_CREATOR_MONTH
  JOKE_OF_DAY
  TRENDING_WEEK
  MOST_COMMENTED_WEEK
  FASTEST_GROWING
  STREAK
}

model BadgeAward {
  id        String   @id @default(uuid())
  userId    Int
  badge     BadgeKey
  language  Language @default(NO)
  awardedAt DateTime @default(now())
  validFrom DateTime?
  validTo   DateTime?
  context   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // one award per user+badge+period start per language
  @@unique([userId, badge, validFrom, language])

  // common queries: user history by language, badge leaderboards by language
  @@index([userId, language, awardedAt])
  @@index([badge, language, awardedAt])
  @@index([language, awardedAt])
}

model CurrentUserBadge {
  id       String   @id @default(uuid())
  userId   Int
  badge    BadgeKey
  language Language @default(NO)
  since    DateTime @default(now())
  validTo  DateTime?
  context  Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // one "current" badge per user+badge per language
  @@unique([userId, badge, language])

  @@index([userId, language])
  @@index([badge, language])
}

model FeaturedPost {
  id        Int         @id @default(autoincrement())
  type      FeatureType
  language  Language    @default(NO)

  // store day as midnight UTC (or period start for week/month features)
  date      DateTime
  postId    Int
  createdAt DateTime    @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  // ensures: daily joke / trending / etc is unique PER language
  @@unique([type, date, language])

  // main lookup patterns
  @@index([language, type, date])
  @@index([language, date])

  // audits and reverse lookups
  @@index([postId])
}

model User {
  id                    Int                  @id @default(autoincrement())
  username              String               @unique
  email                 String               @unique
  password              String
  avatar                String?
  active                Boolean              @default(true)
  role                  Role                 @default(USER)

  emailVerified         Boolean              @default(false)
  emailVerifiedAt       DateTime?

  blogPosts             BlogPost[]
  comments              Comment[]
  likes                 PostLike[]
  refreshTokens         RefreshToken[]
  resetPasswordTokens   ResetPasswordToken[]
  emailVerificationTokens EmailVerificationToken[]

  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @default(now()) @updatedAt
  deletedAt             DateTime?

  termsAcceptedAt       DateTime?
  termsVersion          String?
  preferredLanguage     Language             @default(NO)

  dailyJokeStreak       Int                  @default(0)
  dailyJokeLastViewedAt DateTime?
  dailyJokeBestStreak   Int                  @default(0)

  currentBadges         CurrentUserBadge[]
  badgeAwards           BadgeAward[]
}

model BlogPost {
  id        Int        @id @default(autoincrement())
  authorId  Int
  language  Language   @default(NO)

  title     String
  body      String
  published Boolean    @default(false)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt

  user      User       @relation(fields: [authorId], references: [id])
  comments  Comment[]
  likes     PostLike[]
  tags      Tag[]      @relation("PostTags")
  featuredIn FeaturedPost[]

  // feed/explore pages
  @@index([language, published, createdAt])
  @@index([language, published, updatedAt])

  // deterministic/random selection benefits
  @@index([language, published, id])

  // author profile pages per language
  @@index([authorId, language, createdAt])
}

model Comment {
  id        Int      @id @default(autoincrement())
  authorId  Int
  postId    Int
  body      String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User     @relation(fields: [authorId], references: [id])
  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  // paginated comments for a post
  @@index([postId, createdAt])
}

model Tag {
  id        Int        @id @default(autoincrement())
  language  Language   @default(NO)
  name      String

  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt

  posts     BlogPost[] @relation("PostTags")

  // tag unique per language
  @@unique([language, name])
}

model PostLike {
  postId    Int
  userId    Int
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // one like per user per post
  @@unique([postId, userId])

  // common lookups
  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique
  issuedAt  DateTime
  expiresAt DateTime
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model ResetPasswordToken {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique
  issuedAt  DateTime
  expiresAt DateTime
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique
  issuedAt  DateTime
  expiresAt DateTime
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ModerationTerm {
  id        Int      @id @default(autoincrement())
  term      String   @unique
  category  String?  // profanity, insult, sexual, slur, etc.
  notes     String?  // for admin reference
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}