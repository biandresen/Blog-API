generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Language {
  NO
  EN
}

enum Role {
  ADMIN
  USER
}

enum FeatureType {
  DAILY_JOKE
  TOP_CREATOR_MONTH
  TRENDING_WEEK
  MOST_COMMENTED_WEEK
  FASTEST_GROWING
}

enum BadgeKey {
  ADMIN
  TOP_CREATOR_MONTH
  JOKE_OF_DAY
  TRENDING_WEEK
  MOST_COMMENTED_WEEK
  FASTEST_GROWING
  STREAK
}

enum AuditAction {
  USER_DEACTIVATED
  USER_REACTIVATED
  USER_ROLE_CHANGED
  MODERATION_TERM_CREATED
  MODERATION_TERM_UPDATED
  MODERATION_TERM_DEACTIVATED
  MODERATION_CACHE_RELOADED
  FEATURE_RECOMPUTE_TRIGGERED
}

enum ProductEventType {
  REGISTER_SUCCESS
  EMAIL_VERIFIED
  LOGIN_SUCCESS
  DAILY_JOKE_VIEW
  POST_PUBLISHED
  COMMENT_CREATED
  SEARCH_EXECUTED
}

model BadgeAward {
  id        String   @id @default(uuid())
  userId    Int
  badge     BadgeKey
  language  Language @default(NO)
  awardedAt DateTime @default(now())
  validFrom DateTime?
  validTo   DateTime?
  context   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge, validFrom, language])
  @@index([userId, language, awardedAt])
  @@index([badge, language, awardedAt])
  @@index([language, awardedAt])
}

model CurrentUserBadge {
  id       String   @id @default(uuid())
  userId   Int
  badge    BadgeKey
  language Language @default(NO)
  since    DateTime @default(now())
  validTo  DateTime?
  context  Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge, language])
  @@index([userId, language])
  @@index([badge, language])
}

model FeaturedPost {
  id        Int         @id @default(autoincrement())
  type      FeatureType
  language  Language    @default(NO)
  date      DateTime
  postId    Int
  createdAt DateTime    @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([type, date, language])
  @@index([language, type, date])
  @@index([language, date])
  @@index([postId])
}

model User {
  id                      Int                      @id @default(autoincrement())
  username                String                   @unique
  email                   String                   @unique
  password                String
  avatar                  String?
  active                  Boolean                  @default(true)
  role                    Role                     @default(USER)

  emailVerified           Boolean                  @default(false)
  emailVerifiedAt         DateTime?

  blogPosts               BlogPost[]
  comments                Comment[]
  likes                   PostLike[]
  refreshTokens           RefreshToken[]
  resetPasswordTokens     ResetPasswordToken[]
  emailVerificationTokens EmailVerificationToken[]

  moderationEvents        ModerationEvent[]
  productEvents           ProductEvent[]

  auditLogsAsActor        AuditLog[]               @relation("AuditActor")
  auditLogsAsTarget       AuditLog[]               @relation("AuditTarget")

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @default(now()) @updatedAt
  deletedAt               DateTime?

  termsAcceptedAt         DateTime?
  termsVersion            String?
  preferredLanguage       Language                 @default(NO)

  dailyJokeStreak         Int                      @default(0)
  dailyJokeLastViewedAt   DateTime?
  dailyJokeBestStreak     Int                      @default(0)

  currentBadges           CurrentUserBadge[]
  badgeAwards             BadgeAward[]
}

model BlogPost {
  id         Int            @id @default(autoincrement())
  authorId   Int
  language   Language       @default(NO)

  title      String
  body       String
  published  Boolean        @default(false)

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @default(now()) @updatedAt

  user       User           @relation(fields: [authorId], references: [id])
  comments   Comment[]
  likes      PostLike[]
  tags       Tag[]          @relation("PostTags")
  featuredIn FeaturedPost[]

  @@index([language, published, createdAt])
  @@index([language, published, updatedAt])
  @@index([language, published, id])
  @@index([authorId, language, createdAt])
}

model Comment {
  id        Int      @id @default(autoincrement())
  authorId  Int
  postId    Int
  body      String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User     @relation(fields: [authorId], references: [id])
  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model Tag {
  id        Int        @id @default(autoincrement())
  language  Language   @default(NO)
  name      String

  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt

  posts     BlogPost[] @relation("PostTags")

  @@unique([language, name])
}

model PostLike {
  postId    Int
  userId    Int
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique
  issuedAt  DateTime
  expiresAt DateTime
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model ResetPasswordToken {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique
  issuedAt  DateTime
  expiresAt DateTime
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique
  issuedAt  DateTime
  expiresAt DateTime
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ModerationTerm {
  id        Int      @id @default(autoincrement())
  term      String   @unique
  category  String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model ModerationEvent {
  id              String   @id @default(cuid())
  userId          Int?
  action          String
  blocked         Boolean  @default(true)
  fieldNames      String[]
  matchedTerms    String[]
  matchedVariants String[]
  contentPreview  String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

model AuditLog {
  id           String      @id @default(cuid())
  actorUserId  Int?
  targetUserId Int?
  action       AuditAction
  entityType   String
  entityId     String?
  summary      String
  diff         Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())

  actorUser    User?       @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser   User?       @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

model ProductEvent {
  id         String           @id @default(cuid())
  userId      Int?
  type       ProductEventType
  path       String?
  language   Language?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime         @default(now())

  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([language, createdAt])
  @@index([createdAt])
}